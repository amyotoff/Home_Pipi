# ===========================================
# Home PiPi — Environment Configuration
# ===========================================
# ⚠️  NEVER commit this file to git.
# Copy to .env and fill in your values.
#
# Minimum hardware: Raspberry Pi 4/5 with ≥ 4 GB RAM
# ===========================================

# Telegram (SENSITIVE — keep secret)
TELEGRAM_BOT_TOKEN=your_bot_token_here
HOUSEHOLD_CHAT_ID=-100xxxxxxxxx

# LLM (SENSITIVE — keep secret)
GEMINI_API_KEY=your_gemini_key_here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Browsing
CHROMIUM_CDP_URL=http://127.0.0.1:9222

# IKEA Tradfri (Optional)
IKEA_GATEWAY_IP=192.168.1.xxx
IKEA_SECURITY_CODE=your_security_code_here

# Weather (Open-Meteo, no key needed)
LOCATION_LAT=0.0000
LOCATION_LON=0.0000

# Access Control — comma-separated TG user IDs of household owners
OWNER_TG_IDS=111,222

# Presence Detection (Optional)
OWNER_IP_ADDRESS=192.168.1.xxx

# Mock sensors for local testing (DEVELOPMENT ONLY)
MOCK_SENSORS=false

# Data directory
DATA_DIR=./data

# Timezone
TZ=UTC

# ===========================================
# Outbound Channels (Optional)
# Set env vars to enable — channels auto-register at startup
# ===========================================

# WhatsApp (via Baileys — native protocol, no browser needed)
WHATSAPP_ENABLED=false
# Auth credentials auto-stored in DATA_DIR/whatsapp-auth/ after QR scan

# Discord (SENSITIVE — keep secret)
# DISCORD_BOT_TOKEN=your_discord_bot_token
# DISCORD_CHANNEL_ID=channel_id_for_notifications

# Gmail / SMTP (SENSITIVE — keep secret)
# CONCIERGE_SMTP_HOST=smtp.gmail.com
# CONCIERGE_SMTP_PORT=587
# CONCIERGE_SMTP_USER=your_email@gmail.com
# CONCIERGE_SMTP_PASS=app_password_here
# CONCIERGE_FROM_NAME=Home PiPi
